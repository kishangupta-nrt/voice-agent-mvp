# Server Environment Variables
# Copy this to .env and fill in your values

PORT=3001
NODE_ENV=development

# LLM Provider - Choose ONE of the options below:

# Option 1: Ollama (Recommended - Local, Free, Private)
# Install Ollama first: https://ollama.com
# Then run: ollama pull mistral
# NOTE: The code appends /api/generate automatically, do NOT include it here
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# Option 2: Mistral API (Cloud - Requires API key)
# Get key at: https://console.mistral.ai
# MISTRAL_API_KEY=your_mistral_api_key_here
# MISTRAL_MODEL=mistral-small-latest

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=20

# Supabase - Get these from Project Settings → API
# Create tables first: See database/schema.sql
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_service_role_key_here
SUPABASE_JWT_SECRET=your_jwt_secret_here

# CORS - Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Email (Resend) - Optional, for sending verification emails
# Get key at: https://resend.com
# RESEND_API_KEY=your_resend_api_key_here
# FROM_EMAIL=onboarding@resend.dev
# FRONTEND_URL=http://localhost:5173
